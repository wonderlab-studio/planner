# ── Kaiten API ────────────────────────────────────────────────────────────────
KAITEN_TOKEN=your_kaiten_token_here
KAITEN_BASE_URL=https://your-domain.kaiten.ru/api/latest
KAITEN_SPACE_ID=197396
KAITEN_BOARD_ID=476640
KAITEN_LANE_ID=623640

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Получить токен: @BotFather → /newbot
TELEGRAM_TOKEN=your_bot_token_here
# Свой chat_id: написать боту @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Хранилище состояния ───────────────────────────────────────────────────────
# Путь к SQLite-файлу с флагами утро/вечер
DB_PATH=state.db
